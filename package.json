{
  "name": "ai_pet",
  "version": "1.0.0",
  "description": "AI Pet - Pixel blind-box desktop pet",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --no-sandbox --disable-gpu\"",
    "build": "vue-tsc && vite build",
    "electron:build": "electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vue": "^3.5.0",
    "pinia": "^2.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-store": "^10.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.7.0",
    "vue-tsc": "^2.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.aipet.app",
    "productName": "AI Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
