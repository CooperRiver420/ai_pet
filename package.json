{
  "name": "ai_pet",
  "version": "1.0.0",
  "description": "AI Pet - Pixel blind-box desktop pet",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --no-sandbox --disable-gpu\"",
    "build": "vue-tsc && vite build",
    "electron:build": "electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "pinia": "^3.0.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "build": {
    "appId": "com.aipet.app",
    "productName": "AI Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
